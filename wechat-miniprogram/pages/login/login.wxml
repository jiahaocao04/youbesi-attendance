<view class="login">
  <view class="bg-orb orb-a"></view>
  <view class="bg-orb orb-b"></view>
  <view class="bg-grid"></view>

  <view class="panel card">
    <view class="brand">
      <view class="logo">优</view>
      <view>
        <view class="title">优贝思校外托管中心</view>
        <view class="sub">老师端点名小程序</view>
      </view>
    </view>

    <view class="cloud-pill">云端自动连接 · 多设备同步</view>

    <view class="field">
      <text>用户名</text>
      <input value="{{username}}" bindinput="onUsername" placeholder="请输入账号" />
    </view>
    <view class="field">
      <text>PIN</text>
      <input value="{{pin}}" bindinput="onPin" password type="number" placeholder="请输入 PIN" />
    </view>

    <button class="primary login-btn" loading="{{loading}}" bindtap="login">登录</button>
    <view class="tip">服务器已锁定为云端地址，老师无需填写，避免误改。</view>
  </view>
</view>
