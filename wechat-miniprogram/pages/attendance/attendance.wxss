page {
  background:
    radial-gradient(circle at 14% 0%, rgba(37, 99, 235, 0.12), transparent 34%),
    linear-gradient(180deg, #f7f9ff 0%, #f4f6fb 52%, #eef2f7 100%);
}

.page {
  padding: 16rpx 16rpx 34rpx;
  color: #111827;
}

.top-card,
.roster-card,
.absent-card {
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.07);
}

.top-card {
  position: sticky;
  top: 0;
  z-index: 8;
  padding: 14rpx;
  backdrop-filter: blur(18rpx);
}

.first-line {
  display: grid;
  grid-template-columns: 190rpx 1fr 1fr 1.25fr;
  column-gap: 10rpx;
  align-items: center;
}

.date-pill,
.metric {
  height: 52rpx;
  line-height: 52rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.date-pill {
  padding: 0 12rpx;
  border: 1rpx solid #dbe3ef;
  background: #ffffff;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric {
  background: #f1f5f9;
  color: #334155;
  text-align: center;
}

.class-search-wrap {
  position: relative;
  margin-top: 12rpx;
}

.class-search-box {
  display: grid;
  grid-template-columns: 72rpx minmax(0, 1fr) 70rpx;
  column-gap: 10rpx;
  align-items: center;
  min-height: 70rpx;
  box-sizing: border-box;
  padding: 10rpx 12rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 20rpx;
  background: #ffffff;
}

.search-label {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 900;
}

.class-search-input {
  height: 50rpx;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 900;
}

.search-close {
  height: 42rpx;
  line-height: 42rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  text-align: center;
  font-size: 20rpx;
  font-weight: 900;
}

.class-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 78rpx;
  z-index: 20;
  max-height: 420rpx;
  overflow-y: auto;
  padding: 8rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.14);
}

.class-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  color: #334155;
  font-size: 24rpx;
  font-weight: 900;
}

.class-option.active {
  background: #eff6ff;
  color: #1d4ed8;
}

.no-class {
  padding: 28rpx 0;
  color: #94a3b8;
  text-align: center;
  font-size: 24rpx;
}

.third-line {
  display: grid;
  grid-template-columns: auto auto minmax(0, 1fr) auto;
  column-gap: 12rpx;
  align-items: center;
  min-height: 46rpx;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 800;
}

.save-state {
  min-width: 0;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.save-state.bad {
  color: #dc2626;
}

.admin-link {
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 900;
}

.roster-card,
.absent-card {
  margin-top: 16rpx;
  padding: 10rpx 10rpx 8rpx;
}

.sheet-header,
.sheet-row {
  display: grid;
  grid-template-columns: 210rpx 112rpx 112rpx 130rpx;
  column-gap: 10rpx;
  align-items: center;
}

.sheet-header {
  height: 50rpx;
  padding: 0 2rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 900;
}

.event-col,
.shop-col,
.ap-col {
  text-align: center;
}

.student-item {
  border-top: 1rpx solid #edf2f7;
  border-radius: 16rpx;
}

.student-item.has-event {
  background: rgba(248, 113, 113, 0.13);
}

.sheet-row {
  min-height: 76rpx;
  padding: 6rpx 2rpx;
}

.name-cell {
  display: grid;
  gap: 2rpx;
  min-width: 0;
}

.name {
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.class-tag {
  color: #94a3b8;
  font-size: 18rpx;
  font-weight: 800;
}

.event-input,
.shop-trigger {
  width: 100%;
  height: 52rpx;
  box-sizing: border-box;
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.92);
}

.event-input {
  padding: 0 10rpx;
  color: #111827;
  text-align: left;
  font-size: 22rpx;
  font-weight: 800;
}

.shop-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0f172a;
  font-size: 20rpx;
  font-weight: 900;
}

.shop-trigger.filled {
  border-color: #bfdbfe;
  background: #eff6ff;
  color: #1d4ed8;
}

.ap-cell {
  display: grid;
  grid-template-columns: 58rpx 58rpx;
  column-gap: 10rpx;
}

.ap-btn {
  width: 58rpx;
  height: 52rpx;
  line-height: 52rpx;
  padding: 0;
  border: 1rpx solid #dbe3ef;
  border-radius: 14rpx;
  background: #ffffff;
  color: #475569;
  font-size: 23rpx;
  font-weight: 900;
}

.ap-btn::after {
  border: 0;
}

.ap-btn.active {
  border-color: #16a34a;
  background: #dcfce7;
  color: #14532d;
}

.shopping-panel {
  display: grid;
  grid-template-columns: 74rpx minmax(0, 1fr) 118rpx;
  column-gap: 10rpx;
  align-items: center;
  margin: 0 2rpx 10rpx;
  padding: 10rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.panel-label {
  color: #64748b;
  font-size: 21rpx;
  font-weight: 900;
}

.shop-input {
  height: 52rpx;
  box-sizing: border-box;
  padding: 0 12rpx;
  border: 1rpx solid #dbe3ef;
  border-radius: 14rpx;
  background: #ffffff;
  color: #111827;
  font-size: 23rpx;
  font-weight: 800;
}

.shop-input.amount {
  text-align: center;
}

.absent-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 54rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
}

.back-link {
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 900;
}

.absent-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 78rpx 78rpx minmax(0, 1fr);
  column-gap: 8rpx;
  align-items: center;
  min-height: 72rpx;
  border-top: 1rpx solid #edf2f7;
  color: #334155;
  font-size: 23rpx;
  font-weight: 800;
}

.note {
  color: #be123c;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty {
  padding: 48rpx 0;
  color: #94a3b8;
  text-align: center;
  font-size: 24rpx;
}
