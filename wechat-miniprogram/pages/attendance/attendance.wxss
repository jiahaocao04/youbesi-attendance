page {
  width: 100%;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 16% 0%, rgba(37, 99, 235, 0.12), transparent 34%),
    linear-gradient(180deg, #f7f9ff 0%, #f4f6fb 52%, #eef2f7 100%);
}

.page {
  position: relative;
  width: 100%;
  max-width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
  padding: 16rpx 16rpx 34rpx;
  color: #111827;
}

view,
input,
textarea,
text {
  box-sizing: border-box;
}

.screen-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 120;
  background: rgba(15, 23, 42, 0.08);
}

.top-card,
.roster-card,
.floating-panel {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 46rpx rgba(15, 23, 42, 0.07);
}

.top-card {
  position: sticky;
  top: 0;
  z-index: 150;
  padding: 14rpx;
  backdrop-filter: blur(18rpx);
  overflow: visible;
}

.first-line {
  display: grid;
  grid-template-columns: 54rpx minmax(0, 1.35fr) minmax(0, 0.86fr) minmax(0, 0.86fr) minmax(0, 1.08fr);
  column-gap: 8rpx;
  align-items: center;
}

.add-btn,
.date-pill,
.metric {
  height: 52rpx;
  line-height: 52rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.add-btn {
  background: #0f172a;
  color: #ffffff;
  text-align: center;
  font-size: 32rpx;
}

.date-pill {
  padding: 0 12rpx;
  border: 1rpx solid #dbe3ef;
  background: #ffffff;
  color: #0f172a;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric {
  background: #f1f5f9;
  color: #334155;
  text-align: center;
}

.metric.a {
  background: #dcfce7;
  color: #166534;
}

.metric.p {
  background: #dbeafe;
  color: #1d4ed8;
}

.metric.full {
  background: #f8fafc;
  color: #0f172a;
}

.class-search-wrap {
  position: relative;
  z-index: 190;
  margin-top: 12rpx;
}

.class-search-box {
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr);
  column-gap: 8rpx;
  align-items: center;
  min-height: 70rpx;
  padding: 10rpx 12rpx;
  border: 1rpx solid #bfdbfe;
  border-radius: 20rpx;
  background: #ffffff;
}

.search-label {
  color: #2563eb;
  font-size: 23rpx;
  font-weight: 900;
}

.class-search-input {
  height: 50rpx;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 900;
}

.class-dropdown {
  position: absolute;
  left: 0;
  right: 0;
  top: 78rpx;
  z-index: 240;
  max-height: 596rpx;
  overflow-y: auto;
  padding: 8rpx;
  border: 1rpx solid #dbeafe;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.14);
}

.class-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 58rpx;
  padding: 0 14rpx;
  border-radius: 14rpx;
  color: #334155;
  font-size: 24rpx;
  font-weight: 900;
}

.class-option.active {
  background: #eff6ff;
  color: #1d4ed8;
}

.third-line {
  display: grid;
  grid-template-columns: auto auto minmax(0, 1fr) auto;
  column-gap: 10rpx;
  align-items: center;
  min-height: 46rpx;
  margin-top: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 800;
}

.save-state {
  min-width: 0;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.save-state.bad {
  color: #dc2626;
}

.admin-link {
  height: 40rpx;
  line-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #0f172a;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 900;
}

.roster-card {
  margin-top: 16rpx;
  padding: 12rpx;
  overflow-x: hidden;
}

.roster-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 12rpx;
}

.student-tile {
  min-width: 0;
  padding: 10rpx;
  border: 1rpx solid #edf2f7;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
}

.student-tile.has-event {
  background: rgba(254, 249, 195, 0.86);
  border-color: rgba(234, 179, 8, 0.34);
}

.student-tile.has-shopping {
  border-color: rgba(37, 99, 235, 0.24);
}

.class-header {
  display: inline-flex;
  align-items: center;
  height: 30rpx;
  margin-bottom: 6rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 18rpx;
  font-weight: 900;
}

.name-zone {
  display: block;
  align-items: center;
  min-height: 58rpx;
}

.name-lines {
  min-width: 0;
}

.name {
  display: block;
  color: #111827;
  font-size: 25rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-tags {
  display: flex;
  gap: 6rpx;
  min-height: 24rpx;
  margin-top: 3rpx;
}

.tag {
  height: 24rpx;
  line-height: 24rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  font-size: 16rpx;
  font-weight: 900;
}

.tag.event {
  background: #fef3c7;
  color: #92400e;
}

.tag.shop {
  background: #eff6ff;
  color: #1d4ed8;
}

.ap-cell {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  column-gap: 8rpx;
  margin-top: 10rpx;
}

.ap-btn {
  height: 58rpx;
  line-height: 58rpx;
  border: 1rpx solid #dbe3ef;
  border-radius: 16rpx;
  background: #ffffff;
  color: #475569;
  text-align: center;
  font-size: 26rpx;
  font-weight: 900;
}

.ap-btn.a.active {
  border-color: #16a34a;
  background: #dcfce7;
  color: #14532d;
}

.ap-btn.p.active {
  border-color: #2563eb;
  background: #dbeafe;
  color: #1d4ed8;
}

.floating-panel {
  position: fixed;
  left: 34rpx;
  right: 34rpx;
  top: 22vh;
  z-index: 260;
  padding: 22rpx;
}

.editor-panel {
  top: 18vh;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.panel-title {
  display: block;
  color: #0f172a;
  font-size: 32rpx;
  font-weight: 900;
}

.panel-sub {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 800;
}

.panel-close {
  width: 46rpx;
  height: 46rpx;
  line-height: 42rpx;
  border-radius: 50%;
  background: #f1f5f9;
  color: #0f172a;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
}

.field-title {
  margin: 14rpx 0 8rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 900;
}

.event-textarea {
  width: 100%;
  min-height: 132rpx;
  padding: 14rpx;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
  background: #f8fafc;
  color: #111827;
  font-size: 24rpx;
  font-weight: 800;
}

.shop-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 160rpx;
  gap: 10rpx;
}

.shop-input,
.add-input {
  width: 100%;
  height: 62rpx;
  padding: 0 14rpx;
  border: 1rpx solid #dbe3ef;
  border-radius: 16rpx;
  background: #ffffff;
  color: #111827;
  font-size: 24rpx;
  font-weight: 800;
}

.shop-input.amount {
  text-align: center;
}

.panel-hint {
  margin-top: 14rpx;
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 800;
}

.add-input {
  margin-top: 12rpx;
  background: #f8fafc;
}

.add-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
}

.ghost-action,
.primary-action {
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
}

.ghost-action {
  background: #f1f5f9;
  color: #334155;
}

.primary-action {
  background: #2563eb;
  color: #ffffff;
}

.no-class,
.empty {
  padding: 48rpx 0;
  color: #94a3b8;
  text-align: center;
  font-size: 24rpx;
}
