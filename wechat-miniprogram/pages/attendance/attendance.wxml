<view class="page">
  <view class="top-card">
    <view class="first-line">
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="date-pill">{{date}}</view>
      </picker>
      <view class="metric">A {{summary.a}}</view>
      <view class="metric">P {{summary.p}}</view>
      <view class="metric">全天 {{summary.fullDay}}</view>
    </view>

    <view class="class-search-wrap">
      <view class="class-search-box">
        <text class="search-label">班级</text>
        <input
          class="class-search-input"
          value="{{classSearchText}}"
          placeholder="搜索班级，如 1.1 / 1-1"
          bindfocus="onClassSearchFocus"
          bindinput="onClassSearchInput"
        />
        <view wx:if="{{classSearchOpen}}" class="search-close" bindtap="closeClassSearch">收起</view>
      </view>

      <view wx:if="{{classSearchOpen}}" class="class-dropdown">
        <view
          wx:for="{{filteredClasses}}"
          wx:key="key"
          class="class-option {{selectedClassKey === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="selectClassFromSearch"
        >
          <text>{{item.label}}</text>
          <text>{{item.count}}人</text>
        </view>
        <view wx:if="{{!filteredClasses.length}}" class="no-class">没有找到这个班级</view>
      </view>
    </view>

    <view class="third-line">
      <text>全部人数 {{totalStudentCount}}</text>
      <text>当前 {{records.length}}</text>
      <text class="save-state {{autoSaveText === '保存失败' ? 'bad' : ''}}">{{loading ? '载入中' : (autoSaveText || '自动保存')}}</text>
      <view wx:if="{{isAdmin}}" class="admin-link" bindtap="goAdmin">管理</view>
    </view>
  </view>

  <view wx:if="{{viewMode === 'roster'}}" class="roster-card">
    <view class="sheet-header">
      <view class="student-col">学生</view>
      <view class="event-col">事件</view>
      <view class="shop-col">购物</view>
      <view class="ap-col">考勤</view>
    </view>

    <view wx:for="{{records}}" wx:key="permanent_id" class="student-item {{item.note ? 'has-event' : ''}}">
      <view class="sheet-row">
        <view class="student-col name-cell">
          <text class="name">{{item.seq_in_class}}. {{item.name}}</text>
          <text class="class-tag">{{item.grade}}-{{item.class_no}}</text>
        </view>

        <input
          class="event-col event-input"
          value="{{item.note}}"
          placeholder=""
          data-index="{{index}}"
          bindfocus="onEventFocus"
          bindinput="onEventInput"
          bindblur="onEventBlur"
        />

        <view class="shop-col shop-trigger {{item.shopping_item || item.shopping_amount ? 'filled' : ''}}" data-index="{{index}}" bindtap="openShopping">
          <text wx:if="{{item.shopping_item || item.shopping_amount}}">¥{{item.shopping_amount}}</text>
        </view>

        <view class="ap-col ap-cell">
          <view
            class="ap-btn {{item.lunch_status === 'present' ? 'active' : ''}}"
            data-index="{{index}}"
            data-field="lunch_status"
            bindtap="toggleAP"
          >A</view>
          <view
            class="ap-btn {{item.care_status === 'present' ? 'active' : ''}}"
            data-index="{{index}}"
            data-field="care_status"
            bindtap="toggleAP"
          >P</view>
        </view>
      </view>

      <view wx:if="{{item.shoppingOpen}}" class="shopping-panel">
        <text class="panel-label">购物</text>
        <input
          class="shop-input item"
          placeholder="物品"
          value="{{item.shopping_item}}"
          data-index="{{index}}"
          bindinput="onShoppingItem"
          bindblur="onShoppingBlur"
        />
        <input
          class="shop-input amount"
          placeholder="金额"
          type="digit"
          value="{{item.shopping_amount_text}}"
          data-index="{{index}}"
          bindinput="onShoppingAmount"
          bindblur="onShoppingBlur"
        />
      </view>
    </view>

    <view wx:if="{{!records.length && !loading}}" class="empty">当前班级暂无学生。</view>
  </view>

  <view wx:else class="absent-card">
    <view class="absent-title">
      <text>未到提醒</text>
      <view class="back-link" bindtap="showRoster">返回点名</view>
    </view>
    <view wx:if="{{!absentRecords.length}}" class="empty">当前班级没有未到学生。</view>
    <view wx:for="{{absentRecords}}" wx:key="permanent_id" class="absent-row">
      <view>
        <text class="name">{{item.name}}</text>
        <text class="class-tag">{{item.grade}}-{{item.class_no}}</text>
      </view>
      <text>{{item.lunch_status === 'present' ? 'A到' : 'A未到'}}</text>
      <text>{{item.care_status === 'present' ? 'P到' : 'P未到'}}</text>
      <text class="note">{{item.note}}</text>
    </view>
  </view>
</view>
