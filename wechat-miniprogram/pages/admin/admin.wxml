<view class="page">
  <view class="hero">
    <view>
      <text class="eyebrow">管理员中心</text>
      <text class="title">优贝思经营总览</text>
    </view>
    <picker mode="date" fields="month" value="{{month}}" bindchange="onMonthChange">
      <view class="month">{{month}}</view>
    </picker>
  </view>

  <view class="stats">
    <view class="stat">
      <text class="num">{{dashboard.students_count}}</text>
      <text class="label">学生</text>
    </view>
    <view class="stat">
      <text class="num">{{dashboard.attendance_records}}</text>
      <text class="label">考勤</text>
    </view>
    <view class="stat">
      <text class="num">¥{{dashboard.payment_sum}}</text>
      <text class="label">充值</text>
    </view>
    <view class="stat danger">
      <text class="num">{{dashboard.debt_count}}</text>
      <text class="label">欠费人数</text>
    </view>
  </view>

  <view class="money-card">
    <view>
      <text class="money-label">本月应缴</text>
      <text class="money">¥{{dashboard.total_due}}</text>
    </view>
    <view>
      <text class="money-label">欠费合计</text>
      <text class="money red">¥{{dashboard.debt_total}}</text>
    </view>
    <view>
      <text class="money-label">购物合计</text>
      <text class="money">¥{{dashboard.shopping_total}}</text>
    </view>
  </view>

  <view class="module-grid">
    <view wx:for="{{modules}}" wx:key="key" class="module" data-key="{{item.key}}" bindtap="onModuleTap">
      <text class="module-title">{{item.title}}</text>
      <text class="module-desc">{{item.desc}}</text>
      <text class="module-status">{{item.status}}</text>
    </view>
  </view>
</view>
