page {
  background:
    radial-gradient(circle at 10% 0%, rgba(37, 99, 235, 0.16), transparent 36%),
    linear-gradient(180deg, #f7f9ff 0%, #eef2f7 100%);
}

.page {
  padding: 18rpx;
  color: #111827;
}

.hero,
.stats,
.money-card,
.module {
  border: 1rpx solid rgba(226, 232, 240, 0.9);
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 18rpx 42rpx rgba(15, 23, 42, 0.07);
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx;
}

.eyebrow {
  display: block;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  display: block;
  margin-top: 6rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 900;
}

.month {
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 24rpx;
  font-weight: 900;
}

.stats {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 14rpx;
}

.stat {
  min-width: 0;
  text-align: center;
}

.num {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.label {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 800;
}

.danger .num {
  color: #be123c;
}

.money-card {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 18rpx;
}

.money-label {
  display: block;
  color: #64748b;
  font-size: 20rpx;
  font-weight: 800;
}

.money {
  display: block;
  margin-top: 6rpx;
  color: #0f172a;
  font-size: 25rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.money.red {
  color: #be123c;
}

.module-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.module {
  min-height: 150rpx;
  box-sizing: border-box;
  padding: 18rpx;
}

.module-title {
  display: block;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
}

.module-desc {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 30rpx;
}

.module-status {
  display: inline-block;
  margin-top: 12rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  font-size: 19rpx;
  font-weight: 900;
}
